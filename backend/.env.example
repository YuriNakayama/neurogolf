# Kaggle credentials (for `dev/submit` / `python -m submit`).
# Either set these env vars, or place ~/.kaggle/kaggle.json.
# Get a token at https://www.kaggle.com/settings → Create New API Token.
KAGGLE_USERNAME=
KAGGLE_KEY=

# AWS credentials are only needed IF DVC + S3 is adopted for data/model
# management (undecided for NeuroGolf — see docs/develop/MIGRATION.md).
# When used, they are read from ~/.aws/credentials under the [neurogolf] profile.
