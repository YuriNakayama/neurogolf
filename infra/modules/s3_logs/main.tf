# ---------------------------------------------------------------------------
# s3_logs: 実行ログは bootstrap で作成済みの infra バケット（state と同居、
# logs/ prefix）に書き出す。バケット自体はここで作らず data source で参照し、
# ARN / 名前を下流（IAM ポリシー・タスク環境変数）へ渡すだけにする。
# ---------------------------------------------------------------------------

data "aws_s3_bucket" "infra" {
  bucket = var.bucket_name
}
